# ============================================================
# MPTVI Training Management System — LOCAL (LAN) configuration
# Copy this file to the project root as ".env", then edit the
# marked values. Generate the key with:  php artisan key:generate
# ============================================================

APP_NAME="MPTVI Training System"

# IMPORTANT: keep this as "local" (NOT "production").
# In production the app force-redirects to HTTPS, which breaks a
# plain http:// office network. "local" keeps it on http.
APP_ENV=local

# Hide error details from staff (we are not in production env, but
# still don't want stack traces shown).
APP_DEBUG=false

# Staff reach the app by NAME at http://mptvi.com (see deploy\local\setup.bat
# and client-hostname.bat, which point mptvi.com at the server PC). Leave this
# as mptvi.com unless you changed the port in the vhost — then use
# http://mptvi.com:8080 to match.
APP_URL=http://mptvi.com

# Leave blank — fill with `php artisan key:generate`
APP_KEY=

APP_TIMEZONE=Asia/Manila
APP_LOCALE=en

# ---- Database: self-contained SQLite file (no DB server needed) ----
DB_CONNECTION=sqlite
# (DB_DATABASE defaults to database/database.sqlite — leave unset)

# ---- Sessions / cache: file-based, zero dependencies ----
SESSION_DRIVER=file
SESSION_LIFETIME=480
CACHE_STORE=file
QUEUE_CONNECTION=sync

# ---- Encrypted daily backups (Settings → Backups) ----
# Set a long random secret. Store it somewhere OTHER than this PC —
# an encrypted backup you can't decrypt is useless if the PC is lost.
BACKUP_PASSWORD=

# ---- Mail: not required for the system to run ----
MAIL_MAILER=log

LOG_CHANNEL=stack
LOG_LEVEL=warning

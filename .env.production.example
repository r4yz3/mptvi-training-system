# MPTVI Training Management System — PRODUCTION env template
# Copy to `.env` on the server and fill in the secrets. NEVER commit the real .env.

APP_NAME="MPTVI Training Management System"
APP_ENV=production
APP_KEY=                       # run: php artisan key:generate
APP_DEBUG=false
APP_URL=https://projec06092026.adfirm.net

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

# --- Database (CloudPanel-provisioned MySQL) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mptvi
DB_USERNAME=mptvi
DB_PASSWORD=                   # set to the CloudPanel DB user password

# Sessions/cache/queue on the DB (no Redis dependency to start)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
CACHE_STORE=database
QUEUE_CONNECTION=database

# Documents live on the PRIVATE local disk (served only via authenticated routes)
FILESYSTEM_DISK=local

# --- Mail (configure with the school's SMTP; password resets need this) ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@adfirm.net"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
